#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

have_cmd() {
  command -v "$1" >/dev/null 2>&1
}

if ! have_cmd zsh; then
  printf 'script/test-shell: zsh not found. Install zsh and retry.\n' >&2
  exit 1
fi

if ! have_cmd shellspec; then
  printf 'script/test-shell: shellspec not found. Install ShellSpec and retry.\n' >&2
  exit 1
fi

(cd "$REPO_ROOT" && shellspec --shell zsh)
